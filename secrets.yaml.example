# secrets.yaml — copy this file to secrets.yaml and fill in your own values.


wifi_ssid: "Your_WiFi_Network_Name"
wifi_password: "your_wifi_password"


api_key: "your_api_key_here="

# Shown in captive portal if Wi-Fi fails
fallback_password: "your_fallback_ap_password"

# Your location for sunrise/sunset calculations
# Find coordinates at: https://www.latlong.net/
latitude: 51.5074    # Example: London
longitude: -0.1278
